{
  "name": "gravuresse",
  "version": "2.2.0",
  "description": "Gravuresse - AI Creative Design Desktop App",
  "author": "Gravuresse",
  "license": "MIT",
  "main": "dist/main/main.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "electron-vite dev --config electron.vite.config.mjs",
    "build": "electron-vite build --config electron.vite.config.mjs",
    "test:core": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-core-data.mjs && node scripts/check-entrypoint-globals.mjs",
    "check:runtime": "node scripts/check-runtime-packaging.mjs --dist",
    "check:asar": "node scripts/check-runtime-packaging.mjs --asar",
    "smoke:packaged": "node scripts/smoke-packaged-win.mjs",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview --config electron.vite.config.mjs",
    "release:checksums": "node scripts/release-checksums.mjs",
    "package": "electron-vite build --config electron.vite.config.mjs && npm run check:runtime && electron-builder --win && npm run check:asar && npm run release:checksums",
    "package:dir": "electron-vite build --config electron.vite.config.mjs && npm run check:runtime && electron-builder --win dir --publish=never && npm run check:asar"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.3",
    "vite": "7.3.5"
  },
  "overrides": {
    "@electron/get": {
      "undici": "7.28.0"
    },
    "vite": {
      "esbuild": "0.28.1"
    }
  }
}
